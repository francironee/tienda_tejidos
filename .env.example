# Variables de entorno para producción en PythonAnywhere
# Copia este archivo como .env y reemplaza los valores con tus credenciales reales

# URL base de tu sitio en producción (ejemplo: https://tuusuario.pythonanywhere.com)
BASE_URL=https://tuusuario.pythonanywhere.com

# Access token de Mercado Pago para PRODUCCIÓN
# Obténlo en: https://www.mercadopago.com/developers/panel/credentials
MP_ACCESS_TOKEN=PROD-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Secret key para Flask (genera uno aleatorio)
SECRET_KEY=genera_una_clave_secreta_aleatoria_aqui

# Debug mode (False para producción)
DEBUG=False
